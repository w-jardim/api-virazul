{
  "name": "viraazul-backend",
  "version": "1.0.0",
  "description": "Backend base inicial - Fase 4",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "test:db:alerts": "cross-env NODE_ENV=test jest --runInBand --config jest.db.config.js --testMatch \"<rootDir>/tests-db/alerts.mysql.integration.test.js\"",
    "test:db:finance": "cross-env NODE_ENV=test jest --runInBand --config jest.db.config.js --testMatch \"<rootDir>/tests-db/finance.mysql.integration.test.js\"",
    "test:db:reports": "cross-env NODE_ENV=test jest --runInBand --config jest.db.config.js --testMatch \"<rootDir>/tests-db/reports.mysql.integration.test.js\"",
    "migrate": "node database/migrate.js",
    "seed": "node database/seed.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "google-auth-library": "^9.15.1",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.11.3",
    "puppeteer": "^21.11.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tests"
    ],
    "clearMocks": true
  }
}
