PORT=3000
NODE_ENV=development
TZ=America/Sao_Paulo

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=viraazul
DB_USER=viraazul_user
DB_PASSWORD=virazul_pass

JWT_SECRET=change-me-with-strong-secret
JWT_EXPIRES_IN=1h

CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=10

SUBSCRIPTION_ENFORCE=false
SUBSCRIPTION_BLOCKED_STATUSES=suspended,cancelled,canceled,inactive,expired,past_due

DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=root

# Mercado Pago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_ENVIRONMENT=sandbox
MP_WEBHOOK_URL=https://yourdomain.com/api/v1/billing/webhooks/mercadopago
MP_BACK_URL=http://localhost:3000

# Billing
TRIAL_DAYS=30
PREMIUM_PRICE_CENTS=999
