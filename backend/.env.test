# Ambiente de teste automatizado local:
# - nao usar como base do ambiente manual de desenvolvimento
# - a porta 3307 fica reservada para banco de teste dedicado
NODE_ENV=test
PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=viraazul_test
DB_USER=viraazul_user
DB_PASSWORD=virazul_pass
DB_ADMIN_USER=root
DB_ADMIN_PASSWORD=root
JWT_SECRET=test-secret
JWT_EXPIRES_IN=1h
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=50
SUBSCRIPTION_ENFORCE=false
SUBSCRIPTION_BLOCKED_STATUSES=suspended,cancelled,canceled,inactive,expired,past_due
TZ=America/Sao_Paulo
